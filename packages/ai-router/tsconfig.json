{
  "compilerOptions": {
    "target":           "ES2017",
    "lib":              ["esnext"],
    "module":           "esnext",
    "moduleResolution": "bundler",
    "strict":           true,
    "skipLibCheck":     true,
    "noEmit":           true,
    "esModuleInterop":  true,
    "isolatedModules":  true,
    "composite":        true
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules"]
}
